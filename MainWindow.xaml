<Window x:Class="CybersecurityChatbotGUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cybersecurity Bot" Height="600" Width="800"
        Background="#1E1E2E" WindowStartupLocation="CenterScreen">

    <TabControl Margin="10">

        <!-- ================================================== -->
        <!-- TAB 1: CHAT (Part 2 + Quiz Button)                 -->
        <!-- ================================================== -->
        <TabItem Header="💬 Chat">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- ASCII art -->
                <TextBlock x:Name="AsciiArtBlock" Grid.Row="0" FontFamily="Consolas" 
                           Foreground="Cyan" TextWrapping="Wrap" Margin="5" FontSize="11"/>

                <!-- Quiz Button (NEW) -->
                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="5" 
                            HorizontalAlignment="Right">
                    <Button x:Name="BtnStartQuiz" Content="🎮 Start Quiz" 
                            Click="BtnStartQuiz_Click" 
                            Background="#6f42c1" Foreground="White" 
                            FontWeight="Bold" Padding="10,5" Margin="5,0,0,0"
                            Cursor="Hand"/>
                </StackPanel>

                <!-- Chat history -->
                <ListBox x:Name="ChatHistory" Grid.Row="2" Background="#2D2D3D" 
                         Foreground="White" Margin="5" FontFamily="Segoe UI" FontSize="13"/>

                <!-- Input area -->
                <Grid Grid.Row="3" Margin="5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="UserInput" Grid.Column="0" Background="#3D3D4D" 
                             Foreground="White" FontSize="14" Padding="5" 
                             KeyDown="UserInput_KeyDown"/>
                    <Button x:Name="SendButton" Grid.Column="1" Content="Send" Width="70" 
                            Margin="5,0,0,0" Click="SendButton_Click" 
                            Background="#007ACC" Foreground="White" FontWeight="Bold"/>
                </Grid>
            </Grid>
        </TabItem>

        <!-- ================================================== -->
        <!-- TAB 2: TASK ASSISTANT (Part 3)                     -->
        <!-- ================================================== -->
        <TabItem Header="📋 Task Assistant">
            <Grid Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Add Task Form -->
                <GroupBox Header="➕ Add New Task" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBox x:Name="TxtTaskTitle" Margin="0,5" 
                                 Background="#2D2D3D" Foreground="White" 
                                 Padding="5" FontSize="14"
                                 TextWrapping="Wrap" 
                                 ToolTip="Task title (required)"/>
                        <TextBox x:Name="TxtTaskDesc" Margin="0,5" 
                                 Background="#2D2D3D" Foreground="White" 
                                 Padding="5" FontSize="14"
                                 TextWrapping="Wrap" 
                                 ToolTip="Description (optional)"/>
                        <DatePicker x:Name="DateReminder" Margin="0,5" 
                                    Background="#2D2D3D" Foreground="White"
                                    ToolTip="Reminder date (optional)"/>
                        <Button x:Name="BtnAddTask" Content="Add Task" 
                                Click="BtnAddTask_Click" 
                                Background="#28a745" Foreground="White" 
                                FontWeight="Bold" Padding="10" Margin="0,5"/>
                    </StackPanel>
                </GroupBox>

                <!-- Task List -->
                <GroupBox Header="📋 My Tasks" Grid.Row="2">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <ListView x:Name="LvTasks" Margin="5" 
                                  Background="#2D2D3D" Foreground="White">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="Title" Width="150" 
                                                    DisplayMemberBinding="{Binding Title}"/>
                                    <GridViewColumn Header="Description" Width="200" 
                                                    DisplayMemberBinding="{Binding Description}"/>
                                    <GridViewColumn Header="Reminder" Width="120" 
                                                    DisplayMemberBinding="{Binding ReminderDate, StringFormat='dd/MM/yyyy'}"/>
                                    <GridViewColumn Header="Done" Width="80">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <CheckBox IsChecked="{Binding IsCompleted}" 
                                                          Tag="{Binding Id}" 
                                                          Checked="TaskCompleted_Changed" 
                                                          Unchecked="TaskCompleted_Changed"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                </GridView>
                            </ListView.View>
                        </ListView>

                        <Button x:Name="BtnDeleteTask" Grid.Row="1" 
                                Content="🗑️ Delete Selected" 
                                Click="BtnDeleteTask_Click" 
                                Background="#dc3545" Foreground="White" 
                                FontWeight="Bold" Padding="10" Margin="5"
                                HorizontalAlignment="Right"/>
                    </Grid>
                </GroupBox>
            </Grid>
        </TabItem>

    </TabControl>
</Window>
    