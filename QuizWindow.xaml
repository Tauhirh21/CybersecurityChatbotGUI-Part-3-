<Window x:Class="CybersecurityChatbotGUI.QuizWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="🎮 Cybersecurity Quiz" Height="450" Width="600"
        WindowStartupLocation="CenterOwner"
        Background="#1E1E2E" ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="TblQuestion" Grid.Row="0" 
                   FontSize="18" FontWeight="Bold" Foreground="White"
                   TextWrapping="Wrap" Margin="0,0,0,20"/>

        <StackPanel x:Name="PanelAnswers" Grid.Row="1" Margin="27,0,42,20"/>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="BtnNext" Content="Next" Width="80" Height="30"
                    Margin="5" IsEnabled="False" Click="BtnNext_Click"
                    Background="#007ACC" Foreground="White" FontWeight="Bold"/>
            <Button x:Name="BtnClose" Content="Close" Width="80" Height="30"
                    Margin="5" Click="BtnClose_Click"
                    Background="#dc3545" Foreground="White" FontWeight="Bold"/>
        </StackPanel>
    </Grid>
</Window>
    
